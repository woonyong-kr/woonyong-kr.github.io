---
import IconHash from "@/assets/icons/IconHash.svg";
import { withBase } from "@/utils/getPath";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={withBase(`/tags/${tag}/`)}
    transition:name={tag}
    class:list={[
      "inline-flex items-center gap-1 rounded-full border border-border bg-surface px-3 py-1.5 font-semibold text-muted-foreground transition",
      "hover:border-accent/30 hover:bg-accent/10 hover:text-accent",
      { "text-sm": size === "sm" },
      { "text-base": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-70",
        { "size-4": size === "sm" },
        { "size-4.5": size === "lg" },
      ]}
    />
    {tagName}
  </a>
</li>
