---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, tags = [], featured, ...props } = data;
---

<li class="my-5">
  <article class="surface-panel overflow-hidden p-7 transition duration-200 hover:-translate-y-1 hover:border-accent/25 hover:shadow-[0_28px_70px_-36px_rgba(18,184,134,0.35)] sm:p-8">
    <div class="flex flex-wrap items-center gap-3">
      <Datetime {...props} />
      {
        featured && (
          <span class="rounded-full bg-accent/12 px-3 py-1 text-xs font-semibold text-accent">
            추천 글
          </span>
        )
      }
    </div>

    <a
      href={getPath(id, filePath)}
      class="mt-4 block text-foreground"
    >
      <Heading
        class="text-2xl font-black tracking-[-0.04em] transition hover:text-accent sm:text-[1.9rem]"
        style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
      >
        {title}
      </Heading>
    </a>

    <p class="mt-4 text-[1.02rem] leading-7 text-muted-foreground">
      {description}
    </p>

    <div class="mt-6 flex flex-wrap items-center justify-between gap-4">
      <div class="flex flex-wrap gap-2">
        {tags.slice(0, 3).map(tag => (
          <span class="rounded-full bg-surface-muted px-3 py-1 text-xs font-semibold text-muted-foreground">
            {tag}
          </span>
        ))}
      </div>
      <a
        href={getPath(id, filePath)}
        class="text-sm font-semibold text-accent transition hover:text-accent-strong"
      >
        읽어보기
      </a>
    </div>
  </article>
</li>
