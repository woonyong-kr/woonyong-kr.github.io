---
import { SHARE_LINKS } from "@/constants";
import LinkButton from "./LinkButton.astro";

const URL = Astro.url;
---

{
  SHARE_LINKS.length > 0 && (
    <div class="surface-soft flex flex-none flex-col gap-4 px-5 py-4">
      <span class="text-sm font-semibold text-muted-foreground">
        이 글 공유하기
      </span>
      <div class="flex flex-wrap gap-2">
        {SHARE_LINKS.map(social => (
          <LinkButton
            href={`${social.href + URL}`}
            class="rounded-full border border-border bg-surface px-3 py-2 text-soft transition hover:border-accent/25 hover:text-foreground"
            title={social.linkTitle}
          >
            <social.icon class="inline-block size-4 fill-transparent stroke-current stroke-2" />
            <span class="text-sm font-medium">{social.name}</span>
          </LinkButton>
        ))}
      </div>
    </div>
  )
}
