---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
import { withBase, withoutBase } from "@/utils/getPath";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath = withoutBase(
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname
);

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};

const navLinkClass =
  "rounded-full px-4 py-2 text-sm font-semibold text-muted-foreground transition hover:bg-surface-muted hover:text-foreground";
const iconLinkClass =
  "rounded-full border border-border bg-surface p-2.5 text-soft transition hover:border-accent/25 hover:text-foreground";
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 rounded-full bg-surface px-4 py-2 text-accent shadow-sm backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header class="sticky top-0 z-40 border-b border-border/80 bg-background/90 backdrop-blur-xl">
  <div class="app-layout relative flex min-h-[5rem] items-center justify-between gap-6">
    <a href={withBase("/")} class="text-[1.9rem] font-black tracking-[-0.06em] text-foreground">
      {SITE.title}
    </a>
    <nav id="nav-menu" class="flex items-center gap-2">
      <button
        id="menu-btn"
        class="focus-outline rounded-full border border-border bg-surface p-2.5 text-foreground shadow-sm md:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "absolute top-full right-5 mt-3 hidden w-[15.5rem] flex-col gap-2 rounded-[1.5rem] border border-border bg-surface p-3 shadow-[var(--shadow)]",
          "md:static md:mt-0 md:flex md:w-auto md:flex-row md:items-center md:border-0 md:bg-transparent md:p-0 md:shadow-none",
        ]}
      >
        <li>
          <a
            href={withBase("/posts")}
            class:list={[navLinkClass, { "active-nav": isActive("/posts") }]}
          >
            글
          </a>
        </li>
        <li>
          <a
            href={withBase("/tags")}
            class:list={[navLinkClass, { "active-nav": isActive("/tags") }]}
          >
            태그
          </a>
        </li>
        <li>
          <a
            href={withBase("/about")}
            class:list={[navLinkClass, { "active-nav": isActive("/about") }]}
          >
            소개
          </a>
        </li>
        {
          SITE.showArchives && (
            <li>
              <LinkButton
                href={withBase("/archives")}
                class:list={[
                  iconLinkClass,
                  {
                    "active-nav text-foreground [&>svg]:stroke-accent":
                      isActive("/archives"),
                  },
                ]}
                title="Archives"
                aria-label="archives"
              >
                <IconArchive class="inline-block" />
                <span class="md:sr-only">Archives</span>
              </LinkButton>
            </li>
          )
        }
        <li>
          <LinkButton
            href={withBase("/search")}
            class:list={[
              iconLinkClass,
              { "text-foreground [&>svg]:stroke-accent": isActive("/search") },
            ]}
            title="Search"
            aria-label="search"
          >
            <IconSearch />
            <span class="sr-only">Search</span>
          </LinkButton>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li>
              <button
                id="theme-btn"
                class="focus-outline relative size-11 rounded-full border border-border bg-surface p-3 text-soft shadow-sm hover:text-foreground md:size-10"
                title="Toggles light & dark"
                aria-label="auto"
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>
