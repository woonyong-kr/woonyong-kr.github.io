---
import { withBase, withoutBase } from "@/utils/getPath";

// Remove current url path and remove trailing slash if exists
const currentUrlPath = withoutBase(Astro.url.pathname).replace(/\/+$/, "");

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = currentUrlPath.split("/").slice(1);

// if breadcrumb is Home > Posts > 1 <etc>
// replace Posts with Posts (page number)
if (breadcrumbList[0] === "posts") {
  breadcrumbList.splice(
    0,
    2,
    Number(breadcrumbList[1] || 1) > 1
      ? `글 (페이지 ${breadcrumbList[1]})`
      : "글"
  );
}

// if breadcrumb is Home > Tags > [tag] > [page] <etc>
// replace [tag] > [page] with [tag] (page number)
if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  breadcrumbList.splice(
    1,
    3,
    `${breadcrumbList[1]} ${Number(breadcrumbList[2]) === 1 ? "" : "(페이지 " + breadcrumbList[2] + ")"}`
  );
}

const labelMap: Record<string, string> = {
  posts: "글",
  tags: "태그",
  about: "소개",
  archives: "아카이브",
  search: "검색",
};
---

<nav class="content-layout mt-8 mb-4" aria-label="breadcrumb">
  <ul class="flex flex-wrap items-center gap-2 text-sm text-soft">
    <li>
      <a href={withBase("/")} class="transition hover:text-foreground">홈</a>
      <span aria-hidden="true">/</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span class="font-medium text-muted-foreground" aria-current="page">
              {labelMap[decodeURIComponent(breadcrumb)] ?? decodeURIComponent(breadcrumb)}
            </span>
          </li>
        ) : (
          <li>
            <a
              href={withBase(`/${breadcrumb}/`)}
              class="transition hover:text-foreground"
            >
              {labelMap[breadcrumb] ?? breadcrumb}
            </a>
            <span aria-hidden="true">/</span>
          </li>
        )
      )
    }
  </ul>
</nav>
